# Copy this file to the project root as `.env` and fill in your values.

# Mandatory Binance US API keys
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Optional: default bot configuration
BOT_SYMBOL=ETH/USDT
BOT_TIMEFRAME=1h
BOT_RSI_ENTRY_MIN=52
BOT_RSI_ENTRY_MAX=75
BOT_RSI_EXIT_MIN=45
BOT_BREAKOUT_LOOKBACK=15
BOT_MIN_VOLUME_RATIO=1.15
BOT_MIN_ATR_RATIO=1.00
BOT_REGIME_SYMBOL=BTC/USDT
BOT_REGIME_TIMEFRAME=4h
BOT_REGIME_FAST_SMA_PERIOD=20
BOT_REGIME_SLOW_SMA_PERIOD=50
BOT_RELATIVE_STRENGTH_SYMBOL=BTC/USDT
BOT_RELATIVE_STRENGTH_TIMEFRAME=4h
BOT_RELATIVE_STRENGTH_FAST_SMA_PERIOD=20
BOT_RELATIVE_STRENGTH_SLOW_SMA_PERIOD=50
BOT_ADD_ON_ENABLED=false

# Optional: safer paper-trading default while testing
BOT_PAPER_TRADING=true

# Optional: override the env file path (absolute path)
# BOT_ENV_FILE=/absolute/path/to/your/envfile
